# EditorConfig is awesome: https://editorconfig.org

root = true

[*]
charset = utf-8
indent_style = space
indent_size = 4
max_line_length = off
trim_trailing_whitespace = true
end_of_line = lf
insert_final_newline = true

[*.py]
indent_size = 4

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab